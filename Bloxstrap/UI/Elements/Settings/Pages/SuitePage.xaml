<ui:UiPage
    x:Class="Voidstrap.UI.Elements.Settings.Pages.SuitePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:settings="clr-namespace:Voidstrap.UI.ViewModels.Settings"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="SuitePage"
    d:DataContext="{d:DesignInstance Type=settings:SuiteViewModel}"
    d:DesignHeight="900"
    d:DesignWidth="800"
    Scrollable="True"
    mc:Ignorable="d">

    <StackPanel Margin="0,0,14,20">
        <TextBlock
            Margin="0,0,0,4"
            FontSize="28"
            FontWeight="Bold"
            Text="Voidstrap Suite 2.0" />
        <TextBlock
            Margin="0,0,0,16"
            FontSize="14"
            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
            TextWrapping="Wrap">
            One place to back up or move your whole launcher profile: settings, UI state, and FastFlags (including the mods ClientAppSettings file).
        </TextBlock>

        <ui:InfoBar
            Margin="0,0,0,12"
            IsClosable="False"
            IsOpen="True"
            Message="Import replaces data on disk immediately. Restart Voidstrap after importing so every screen reloads."
            Severity="Informational" />

        <ui:CardAction
            Margin="0,0,0,8"
            Command="{Binding ExportSuiteBundleCommand}"
            Icon="ArrowExportRtl24">
            <StackPanel>
                <TextBlock FontSize="16" FontWeight="SemiBold" Text="Export suite backup" />
                <TextBlock
                    Margin="0,4,0,0"
                    FontSize="12"
                    Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                    Text="Save a single .voidstrap.json file you can store on a drive or share between PCs."
                    TextWrapping="Wrap" />
            </StackPanel>
        </ui:CardAction>

        <ui:CardAction
            Margin="0,0,0,16"
            Command="{Binding ImportSuiteBundleCommand}"
            Icon="ArrowImport24">
            <StackPanel>
                <TextBlock FontSize="16" FontWeight="SemiBold" Text="Import suite backup" />
                <TextBlock
                    Margin="0,4,0,0"
                    FontSize="12"
                    Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                    Text="Load a previously exported suite file. You will be asked to confirm before anything is overwritten."
                    TextWrapping="Wrap" />
            </StackPanel>
        </ui:CardAction>

        <TextBlock
            Margin="0,8,0,8"
            FontSize="18"
            FontWeight="SemiBold"
            Text="What’s included in 2.0" />
        <TextBlock
            Margin="0,0,0,6"
            FontSize="13"
            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
            TextWrapping="Wrap">
            • <Run FontWeight="SemiBold" Text="Suite hub" /> — full profile export/import (settings + state + FastFlags)&#x0a;
            • <Run FontWeight="SemiBold" Text="Earlier 1.x features" /> — death sound tools, path shortcuts, FastFlags JSON export, logs folder — all still on their pages.
        </TextBlock>
    </StackPanel>
</ui:UiPage>
